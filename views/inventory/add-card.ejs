<h1>Add Card</h1>

<form method="POST">

<label>Name</label>
<input name="name" required>

<label>Description</label>
<textarea name="description"></textarea>

<label>Price</label>
<input type="number" step="0.01" name="price">

<label>Rarity</label>
<input name="rarity">

<label>Set ID</label>
<input name="set_id">

<button type="submit">Add Card</button>

</form>