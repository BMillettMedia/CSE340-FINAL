<h1>Add Card</h1>

<form method="POST">

    <label>Name</label>
    <input name="name" required>

    <label>Description</label>
    <textarea name="description"></textarea>

    <label>Price</label>
    <input type="number" step="0.01" name="price">

    <label>Rarity</label>
    <input name="rarity">

    <!--Card set for form-->
    <label>Card Set</label>

        <select name="set_id">

        <% sets.forEach(set => { %>

        <option value="<%= set.id %>">
        <%= set.name %>
        </option>

        <% }) %>

        </select>

    <button type="submit">Add Card</button>

</form>