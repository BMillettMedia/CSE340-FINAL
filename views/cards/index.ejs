<%- include("../layout/main", {title: title, nav: nav, content: ""}) %>

<h2>Card Inventory</h2>

<div class="card-grid">

<% if(cards && cards.length > 0){ %>

  <% cards.forEach(card => { %>

    <div class="card">

      <h3><%= card.name %></h3>

      <p><%= card.description %></p>

      <p>Price: $<%= card.price %></p>

      <p>Rarity: <%= card.rarity %></p>

      <a href="/cards/<%= card.id %>">View Card</a>

    </div>

  <% }) %>

<% } else { %>

<p>No cards found.</p>

<% } %>

</div>