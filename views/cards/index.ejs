<h1>Card Inventory</h1>

<div class="card-grid">

<% cards.forEach(card => { %>

<div class="card">

<h3><%= card.card_name %></h3>

<p><strong>Type:</strong> <%= card.card_type %></p>

<p><strong>ATK:</strong> <%= card.card_attack %></p>

<a href="/cards/<%= card.card_id %>">View Card</a>

</div>

<% }) %>

</div>