<h1>Card Inventory</h1>

<div class="card-grid">

    <% cards.forEach(card => { %>

    <div class="card">

        <h3><%= card.name %></h3>

        <p><strong>Set:</strong> <%= card.set_name %></p>

        <p><strong>Rarity:</strong> <%= card.rarity %></p>

        <p>$<%= card.price %></p>

        <a href="/cards/<%= card.id %>" class="btn">
        View Details
        </a>

    </div>

    <% }) %>

</div>