<div class="card-detail">

<h1><%= card.card_name %></h1>

<p><strong>Type:</strong> <%= card.card_type %></p>
<p><strong>Attribute:</strong> <%= card.card_attribute %></p>
<p><strong>ATK:</strong> <%= card.card_attack %></p>
<p><strong>DEF:</strong> <%= card.card_defense %></p>

<p><%= card.card_description %></p>

</div>


<h2>Reviews</h2>

<% if(reviews.length === 0){ %>

<p>No reviews yet.</p>

<% } %>


<div class="reviews-list">

<% reviews.forEach(review => { %>

<div class="review">

<strong><%= review.account_firstname %></strong>

<p><strong>Rating:</strong> <%= review.review_rating %>/5</p>

<p><%= review.review_text %></p>

</div>

<% }) %>

</div>

<p>
<strong>Average Rating:</strong>

<% if(average && average.average_rating){ %>

<%= average.average_rating %> / 5

<% } else { %>

No ratings yet

<% } %>

</p>


<% if(account){ %>

<h3>Leave a Review</h3>

<form action="/reviews/add" method="POST">

<input type="hidden" name="card_id" value="<%= card.card_id %>">

<label for="review_rating">Rating</label>

<select name="review_rating" id="review_rating" required>

<option value="5">5 - Excellent</option>
<option value="4">4 - Good</option>
<option value="3">3 - Average</option>
<option value="2">2 - Poor</option>
<option value="1">1 - Terrible</option>

</select>

<label for="review_text">Your Review</label>

<textarea 
name="review_text" 
id="review_text" 
placeholder="Share your thoughts about this card..."
required></textarea>

<button type="submit">Submit Review</button>

</form>

<% } else { %>

<p><a href="/account/login">Log in</a> to leave a review.</p>

<% } %>


<br>

<a class="btn" href="/cards">Back to Cards</a>